{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SafeOps IDS/IPS Alert Log Schema",
  "description": "Schema for ids.log - filtered and deduplicated network alerts with application layer data",
  "type": "object",
  "required": ["timestamp_ist", "packet_id", "src_ip", "dst_ip", "protocol"],
  "properties": {
    "timestamp_ist": {
      "type": "string",
      "description": "Timestamp in Indian Standard Time (IST)",
      "format": "YYYY-MM-DD HH:MM:SS IST",
      "example": "2025-10-27 14:30:45 IST"
    },
    "packet_id": {
      "type": "string",
      "description": "Unique packet identifier for correlation with network_packets.log",
      "example": "pkt_1698412845123_a1b2c3d4"
    },
    "src_ip": {
      "type": "string",
      "description": "Source IP address (IPv4 or IPv6)",
      "examples": ["192.168.1.100", "2001:db8::1"]
    },
    "dst_ip": {
      "type": "string",
      "description": "Destination IP address (IPv4 or IPv6)",
      "examples": ["10.0.0.50", "2001:db8::2"]
    },
    "src_port": {
      "type": "integer",
      "description": "Source port (optional, present for TCP/UDP)",
      "minimum": 0,
      "maximum": 65535,
      "example": 54321
    },
    "dst_port": {
      "type": "integer",
      "description": "Destination port (optional, present for TCP/UDP)",
      "minimum": 0,
      "maximum": 65535,
      "example": 443
    },
    "protocol": {
      "type": "string",
      "description": "Network protocol",
      "enum": ["TCP", "UDP", "ICMP", "UNKNOWN"],
      "example": "TCP"
    },
    "http": {
      "type": "object",
      "description": "HTTP/HTTPS metadata (only present if HTTP traffic detected)",
      "properties": {
        "method": {
          "type": "string",
          "description": "HTTP method",
          "examples": ["GET", "POST", "PUT", "DELETE"]
        },
        "host": {
          "type": "string",
          "description": "HTTP Host header",
          "example": "api.example.com"
        },
        "uri": {
          "type": "string",
          "description": "Request URI/path",
          "example": "/api/v1/users"
        },
        "url": {
          "type": "string",
          "description": "Full reconstructed URL",
          "example": "https://api.example.com/api/v1/users"
        },
        "status_code": {
          "type": "integer",
          "description": "HTTP response status code",
          "example": 200
        },
        "user_agent": {
          "type": "string",
          "description": "User-Agent header",
          "example": "Mozilla/5.0 (Windows NT 10.0; Win64; x64)"
        },
        "content_type": {
          "type": "string",
          "description": "Content-Type header",
          "example": "application/json"
        }
      }
    },
    "dns": {
      "type": "object",
      "description": "DNS query/response metadata (only present if DNS traffic detected)",
      "properties": {
        "query": {
          "type": "string",
          "description": "DNS query domain name",
          "example": "example.com"
        },
        "query_type": {
          "type": "string",
          "description": "DNS query type (A, AAAA, MX, etc.)",
          "examples": ["1", "28", "15"]
        },
        "answers": {
          "type": "array",
          "description": "DNS response answers (max 10)",
          "items": {
            "type": "string"
          },
          "example": ["93.184.216.34", "2606:2800:220:1:248:1893:25c8:1946"]
        },
        "ttl": {
          "type": "integer",
          "description": "Time-to-live from first answer",
          "example": 300
        },
        "response_code": {
          "type": "string",
          "description": "DNS response code (0=NOERROR, 3=NXDOMAIN, etc.)",
          "example": "0"
        }
      }
    },
    "tls": {
      "type": "object",
      "description": "TLS/SSL metadata (only present if TLS traffic detected)",
      "properties": {
        "sni": {
          "type": "string",
          "description": "Server Name Indication from Client Hello",
          "example": "secure.example.com"
        },
        "version": {
          "type": "string",
          "description": "TLS version",
          "examples": ["TLS 1.2", "TLS 1.3"]
        },
        "alpn": {
          "type": "string",
          "description": "Application-Layer Protocol Negotiation (comma-separated)",
          "example": "h2,http/1.1"
        },
        "cipher_suites": {
          "type": "array",
          "description": "Client cipher suites (first 5)",
          "items": {
            "type": "string"
          },
          "example": ["TLS_AES_128_GCM_SHA256", "TLS_AES_256_GCM_SHA384"]
        },
        "selected_cipher": {
          "type": "string",
          "description": "Server-selected cipher suite",
          "example": "TLS_AES_128_GCM_SHA256"
        },
        "decrypted": {
          "type": "boolean",
          "description": "Whether TLS was successfully decrypted",
          "example": true
        }
      }
    },
    "ssh": {
      "type": "object",
      "description": "SSH metadata (only present if SSH traffic detected)",
      "properties": {
        "version": {
          "type": "string",
          "description": "SSH protocol version",
          "example": "SSH-2.0"
        },
        "banner": {
          "type": "string",
          "description": "SSH server banner",
          "example": "OpenSSH_8.9p1 Ubuntu-3ubuntu0.1"
        }
      }
    },
    "ftp": {
      "type": "object",
      "description": "FTP metadata (only present if FTP traffic detected)",
      "properties": {
        "command": {
          "type": "string",
          "description": "FTP command",
          "examples": ["USER", "PASS", "RETR", "STOR"]
        },
        "filename": {
          "type": "string",
          "description": "File being transferred",
          "example": "document.pdf"
        }
      }
    },
    "smtp": {
      "type": "object",
      "description": "SMTP metadata (only present if SMTP traffic detected)",
      "properties": {
        "from": {
          "type": "string",
          "description": "Email sender",
          "example": "sender@example.com"
        },
        "to": {
          "type": "string",
          "description": "Email recipient",
          "example": "recipient@example.com"
        },
        "subject": {
          "type": "string",
          "description": "Email subject line",
          "example": "Important Message"
        }
      }
    },
    "tcp_flags": {
      "type": "string",
      "description": "TCP flags as abbreviated string (only for TCP with meaningful flags)",
      "pattern": "^[SAFRPU]+$",
      "examples": ["SA", "PA", "FA"],
      "legend": {
        "S": "SYN",
        "A": "ACK",
        "F": "FIN",
        "R": "RST",
        "P": "PSH",
        "U": "URG"
      }
    },
    "session_id": {
      "type": "string",
      "description": "Session/Flow ID for correlation across packets",
      "example": "flow_1698412845_a1b2c3d4"
    },
    "bytes": {
      "type": "integer",
      "description": "Total bytes transferred in flow (only if > 0)",
      "minimum": 1,
      "example": 4096
    },
    "gaming_service": {
      "type": "string",
      "description": "Detected gaming service (only if gaming traffic detected)",
      "examples": ["Steam", "Epic Games", "Unknown"]
    }
  },
  "examples": [
    {
      "timestamp_ist": "2025-10-27 14:30:45 IST",
      "packet_id": "pkt_1698412845123_a1b2c3d4",
      "src_ip": "192.168.1.100",
      "dst_ip": "93.184.216.34",
      "src_port": 54321,
      "dst_port": 443,
      "protocol": "TCP",
      "tls": {
        "sni": "example.com",
        "version": "TLS 1.3",
        "alpn": "h2,http/1.1"
      },
      "tcp_flags": "PA",
      "session_id": "flow_1698412845_a1b2c3d4",
      "bytes": 2048
    },
    {
      "timestamp_ist": "2025-10-27 14:31:12 IST",
      "packet_id": "pkt_1698412872456_e5f6g7h8",
      "src_ip": "10.0.0.50",
      "dst_ip": "8.8.8.8",
      "src_port": 62345,
      "dst_port": 53,
      "protocol": "UDP",
      "dns": {
        "query": "api.github.com",
        "query_type": "1",
        "answers": ["140.82.121.6"],
        "ttl": 60,
        "response_code": "0"
      }
    },
    {
      "timestamp_ist": "2025-10-27 14:32:05 IST",
      "packet_id": "pkt_1698412925789_i9j0k1l2",
      "src_ip": "192.168.1.150",
      "dst_ip": "104.16.132.229",
      "src_port": 49876,
      "dst_port": 80,
      "protocol": "TCP",
      "http": {
        "method": "GET",
        "host": "www.cloudflare.com",
        "uri": "/api/status",
        "url": "http://www.cloudflare.com/api/status",
        "status_code": 200,
        "user_agent": "curl/7.68.0",
        "content_type": "application/json"
      },
      "tcp_flags": "PA",
      "bytes": 1024
    }
  ],
  "filtering_notes": {
    "description": "This log contains ONLY packets with application layer data",
    "excluded_traffic": [
      "TCP handshakes (SYN, SYN-ACK)",
      "TCP connection close (FIN, RST)",
      "Pure TCP ACK packets (no data)",
      "Packets without application layer protocols"
    ],
    "deduplication": {
      "strategy": "connection-based (5-tuple)",
      "window": "600 seconds (10 minutes)",
      "udp": "Exact payload deduplication (stateless)",
      "tcp": "Per-connection payload tracking (stateful)"
    }
  },
  "field_ordering": {
    "description": "Fields appear in analyst-friendly order",
    "priority": [
      "timestamp_ist",
      "packet_id",
      "src_ip",
      "dst_ip",
      "src_port (optional)",
      "dst_port (optional)",
      "protocol",
      "protocol_specific_data (http/dns/tls/ssh/ftp/smtp)",
      "tcp_flags (optional)",
      "session_id (optional)",
      "bytes (optional)",
      "gaming_service (optional)"
    ]
  },
  "performance_characteristics": {
    "batch_size": 100,
    "batch_timeout": "1 second",
    "rotation_interval": "3 minutes (follows network_packets.log)",
    "deduplication_cache": "50,000 connections max",
    "cache_cleanup_interval": "60 seconds"
  }
}