{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SafeOps NetFlow Schema - Flow Aggregation Edition",
  "description": "Compact NetFlow JSON-lines schema for flow-aggregated network traffic with geo intelligence and unknown IP tracking. Optimized for analyst-facing netflow storage with 100x space reduction.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "timestamp",
    "event_id",
    "flow_id",
    "log_type",
    "event_type",
    "source_ip",
    "destination_ip",
    "protocol"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Flow start timestamp in ISO 8601 format (UTC)"
    },
    "event_id": {
      "type": "string",
      "description": "Unique event identifier (from first packet or generated)"
    },
    "flow_id": {
      "type": "integer",
      "description": "Unique flow identifier generated from 5-tuple hash",
      "minimum": 0
    },
    "log_source": {
      "type": "string",
      "description": "Source system generating the log (optional)",
      "default": "netflow_writer"
    },
    "log_type": {
      "type": "string",
      "enum": ["netflow"],
      "description": "Log type identifier"
    },
    "event_type": {
      "type": "string",
      "enum": ["flow"],
      "description": "Event type for flow records"
    },
    "version": {
      "type": "string",
      "description": "Schema version (optional)",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },

    "source_ip": {
      "type": "string",
      "description": "Source IP address (IPv4 or IPv6)",
      "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}$|^([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}$"
    },
    "destination_ip": {
      "type": "string",
      "description": "Destination IP address (IPv4 or IPv6)",
      "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}$|^([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}$"
    },
    "source_port": {
      "type": ["integer", "null"],
      "description": "Source port number (null for ICMP)",
      "minimum": 0,
      "maximum": 65535
    },
    "destination_port": {
      "type": ["integer", "null"],
      "description": "Destination port number (null for ICMP)",
      "minimum": 0,
      "maximum": 65535
    },
    "protocol": {
      "type": "string",
      "description": "Transport protocol name",
      "enum": ["tcp", "udp", "icmp", "icmpv6", "gre", "esp", "ah", "sctp"]
    },

    "network_layer": {
      "type": "object",
      "description": "Network and transport layer details",
      "additionalProperties": false,
      "required": ["src_ip", "dst_ip", "protocol"],
      "properties": {
        "src_ip": {
          "type": "string",
          "description": "Source IP address"
        },
        "dst_ip": {
          "type": "string",
          "description": "Destination IP address"
        },
        "src_port": {
          "type": ["integer", "null"],
          "description": "Source port number",
          "minimum": 0,
          "maximum": 65535
        },
        "dst_port": {
          "type": ["integer", "null"],
          "description": "Destination port number",
          "minimum": 0,
          "maximum": 65535
        },
        "protocol": {
          "type": "string",
          "description": "Protocol name (tcp, udp, icmp, etc.)"
        },
        "protocol_number": {
          "type": "integer",
          "description": "IANA protocol number (6=TCP, 17=UDP, 1=ICMP)",
          "minimum": 0,
          "maximum": 255
        },
        "ip_version": {
          "type": "integer",
          "enum": [4, 6],
          "description": "IP version (4 or 6)"
        },
        "ttl": {
          "type": "integer",
          "description": "Time to Live (IPv4) or Hop Limit (IPv6)",
          "minimum": 0,
          "maximum": 255
        },
        "packet_length": {
          "type": "integer",
          "description": "Packet length in bytes (optional)",
          "minimum": 0
        }
      }
    },

    "flow_statistics": {
      "type": "object",
      "description": "Aggregated flow statistics and metadata",
      "additionalProperties": false,
      "required": [
        "direction",
        "initiator",
        "start_timestamp",
        "end_timestamp",
        "duration",
        "bytes",
        "packets"
      ],
      "properties": {
        "direction": {
          "type": "string",
          "enum": ["east-west", "north-south"],
          "description": "Traffic direction: east-west (private-to-private) or north-south (private-to-internet)"
        },
        "initiator": {
          "type": "string",
          "enum": ["local", "internet", "unknown"],
          "description": "Flow initiator classification"
        },
        "start_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Flow start time (first packet timestamp)"
        },
        "end_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Flow end time (last packet timestamp)"
        },
        "duration": {
          "type": "number",
          "minimum": 0,
          "description": "Flow duration in seconds (end - start)"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Total bytes transferred in both directions"
        },
        "bytes_toserver": {
          "type": "integer",
          "minimum": 0,
          "description": "Bytes sent from client to server"
        },
        "bytes_toclient": {
          "type": "integer",
          "minimum": 0,
          "description": "Bytes sent from server to client"
        },
        "packets": {
          "type": "integer",
          "minimum": 0,
          "description": "Total packets in both directions"
        },
        "packets_toserver": {
          "type": "integer",
          "minimum": 0,
          "description": "Packets sent from client to server"
        },
        "packets_toclient": {
          "type": "integer",
          "minimum": 0,
          "description": "Packets sent from server to client"
        },
        "state": {
          "type": "string",
          "enum": ["NEW", "SYN_SENT", "SYN_RECEIVED", "ESTABLISHED", "FIN_WAIT", "RESET", "CLOSED"],
          "description": "TCP connection state (only for TCP flows)"
        },
        "reason": {
          "type": "string",
          "description": "Flow classification reason (e.g., 'both_endpoints_are_rfc1918')"
        }
      }
    },

    "bytes": {
      "type": "integer",
      "minimum": 0,
      "description": "Total bytes transferred (top-level for quick access)"
    },
    "packets": {
      "type": "integer",
      "minimum": 0,
      "description": "Total packets transferred (top-level for quick access)"
    },

    "geo": {
      "type": "object",
      "description": "Geographic intelligence for source and destination IPs",
      "additionalProperties": false,
      "properties": {
        "src_country": {
          "type": "string",
          "description": "Source IP country name (or 'Private' for RFC1918, or empty for unknown)"
        },
        "src_country_code": {
          "type": "string",
          "description": "Source IP ISO 3166-1 alpha-2 country code (or 'XX' for private)",
          "pattern": "^[A-Z]{2}$|^$"
        },
        "src_asn": {
          "type": ["integer", "null"],
          "description": "Source IP Autonomous System Number (optional)",
          "minimum": 0
        },
        "src_asn_org": {
          "type": "string",
          "description": "Source IP ASN organization name"
        },
        "dst_country": {
          "type": "string",
          "description": "Destination IP country name (or 'Private' for RFC1918, or empty for unknown)"
        },
        "dst_country_code": {
          "type": "string",
          "description": "Destination IP ISO 3166-1 alpha-2 country code (or 'XX' for private)",
          "pattern": "^[A-Z]{2}$|^$"
        },
        "dst_asn": {
          "type": ["integer", "null"],
          "description": "Destination IP Autonomous System Number (optional)",
          "minimum": 0
        },
        "dst_asn_org": {
          "type": "string",
          "description": "Destination IP ASN organization name"
        }
      }
    },

    "meta": {
      "type": "object",
      "description": "Metadata about the flow record",
      "additionalProperties": true,
      "properties": {
        "device_id": {
          "type": "string",
          "description": "Device/host that captured this flow"
        },
        "packet_id": {
          "type": "string",
          "description": "Last packet ID in the flow"
        },
        "flow_key": {
          "type": "string",
          "description": "Internal flow key (optional, for debugging)"
        },
        "aggregation_method": {
          "type": "string",
          "enum": ["5-tuple", "bidirectional"],
          "description": "Flow aggregation method used"
        }
      }
    },

    "netflow_data": {
      "type": "object",
      "description": "Additional NetFlow-specific fields (for compatibility)",
      "additionalProperties": true,
      "properties": {
        "version": {
          "type": ["integer", "string"],
          "description": "NetFlow version (5, 9, 10/IPFIX)"
        },
        "template_id": {
          "type": "integer",
          "description": "NetFlow v9/IPFIX template ID"
        },
        "export_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "NetFlow export timestamp"
        },
        "input_snmp": {
          "type": "integer",
          "description": "Input SNMP interface index"
        },
        "output_snmp": {
          "type": "integer",
          "description": "Output SNMP interface index"
        },
        "next_hop": {
          "type": "string",
          "description": "Next hop IP address"
        },
        "sampling_interval": {
          "type": "integer",
          "minimum": 1,
          "description": "Packet sampling interval"
        },
        "src_as": {
          "type": "integer",
          "description": "Source Autonomous System number"
        },
        "dst_as": {
          "type": "integer",
          "description": "Destination Autonomous System number"
        }
      }
    },

    "threat_intel": {
      "type": "object",
      "description": "Threat intelligence enrichment (optional)",
      "additionalProperties": true,
      "properties": {
        "ioc_match": {
          "type": "boolean",
          "description": "Whether this flow matched any IOC"
        },
        "reputation_score": {
          "type": "number",
          "description": "IP reputation score (0-100, lower is worse)"
        },
        "malicious": {
          "type": "boolean",
          "description": "Whether IP is flagged as malicious"
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Threat categories (malware, botnet, phishing, etc.)"
        }
      }
    },

    "file": {
      "type": "object",
      "description": "File transfer metadata (optional, for protocol analysis)",
      "additionalProperties": false,
      "properties": {
        "filename": {
          "type": "string",
          "description": "Transferred filename"
        },
        "file_hashes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "md5": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{32}$"
            },
            "sha1": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{40}$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{64}$"
            }
          }
        }
      }
    }
  }
}