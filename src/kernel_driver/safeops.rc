//=============================================================================
// safeops.rc - SafeOps Kernel Driver Version Resource Script
//=============================================================================
// Copyright (c) 2025 SafeOps Security, Inc. All rights reserved.
//
// This resource file embeds version information into the compiled driver.
// The version information is displayed in Windows Explorer file properties,
// Device Manager, and used by Windows Update for version comparison.
//=============================================================================

#include <windows.h>
#include <ntverp.h>

//=============================================================================
// Version Number Definitions
//=============================================================================

#define VER_PRODUCTMAJORVERSION     2
#define VER_PRODUCTMINORVERSION     0
#define VER_PRODUCTBUILD            0
#define VER_PRODUCTBUILD_QFE        1

// Comma-separated version for VERSIONINFO (Major,Minor,Build,QFE)
#define VER_FILEVERSION             VER_PRODUCTMAJORVERSION,VER_PRODUCTMINORVERSION,VER_PRODUCTBUILD,VER_PRODUCTBUILD_QFE
#define VER_PRODUCTVERSION          VER_PRODUCTMAJORVERSION,VER_PRODUCTMINORVERSION,VER_PRODUCTBUILD,VER_PRODUCTBUILD_QFE

// String versions for display
#define VER_FILEVERSION_STR         "2.0.0.1"
#define VER_PRODUCTVERSION_STR      "2.0.0.1"

//=============================================================================
// File Type and Subtype
//=============================================================================

#define VER_FILETYPE                VFT_DRV
#define VER_FILESUBTYPE             VFT2_DRV_NETWORK
#define VER_FILEOS                  VOS_NT_WINDOWS32

//=============================================================================
// Company and Product Information
//=============================================================================

#define VER_COMPANYNAME_STR         "SafeOps Security, Inc."
#define VER_PRODUCTNAME_STR         "SafeOps Network Security Gateway"
#define VER_FILEDESCRIPTION_STR     "SafeOps Network Security Filter Driver"
#define VER_INTERNALNAME_STR        "safeops.sys"
#define VER_ORIGINALFILENAME_STR    "safeops.sys"

//=============================================================================
// Legal Information
//=============================================================================

#define VER_LEGALCOPYRIGHT_STR      "Copyright (C) 2025 SafeOps Security, Inc. All rights reserved."
#define VER_LEGALTRADEMARKS_STR     "SafeOps is a trademark of SafeOps Security, Inc."

//=============================================================================
// Additional Metadata
//=============================================================================

#define VER_COMMENTS_STR            "High-performance kernel-mode network security driver for packet capture, deep packet inspection, and firewall filtering. Supports 10Gbps+ throughput."
#define VER_PRIVATEBUILD_STR        "Built by SafeOps CI/CD Pipeline"
#define VER_SPECIALBUILD_STR        ""

//=============================================================================
// Build Configuration Flags
//=============================================================================

// FILEFLAGS based on build type
#ifdef DBG
  #define VER_DEBUG_FLAG            VS_FF_DEBUG
#else
  #define VER_DEBUG_FLAG            0
#endif

#ifdef PRERELEASE
  #define VER_PRERELEASE_FLAG       VS_FF_PRERELEASE
#else
  #define VER_PRERELEASE_FLAG       0
#endif

#ifdef PRIVATEBUILD
  #define VER_PRIVATEBUILD_FLAG     VS_FF_PRIVATEBUILD
#else
  #define VER_PRIVATEBUILD_FLAG     0
#endif

#ifdef SPECIALBUILD
  #define VER_SPECIALBUILD_FLAG     VS_FF_SPECIALBUILD
#else
  #define VER_SPECIALBUILD_FLAG     0
#endif

#define VER_FILEFLAGS               (VER_DEBUG_FLAG | VER_PRERELEASE_FLAG | VER_PRIVATEBUILD_FLAG | VER_SPECIALBUILD_FLAG)

//=============================================================================
// VS_VERSION_INFO Resource Block
//=============================================================================

VS_VERSION_INFO VERSIONINFO
    FILEVERSION     VER_FILEVERSION
    PRODUCTVERSION  VER_PRODUCTVERSION
    FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
    FILEFLAGS       VER_FILEFLAGS
    FILEOS          VER_FILEOS
    FILETYPE        VER_FILETYPE
    FILESUBTYPE     VER_FILESUBTYPE
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        // Language: US English (0x0409), Code Page: Unicode (1200)
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      VER_COMPANYNAME_STR
            VALUE "FileDescription",  VER_FILEDESCRIPTION_STR
            VALUE "FileVersion",      VER_FILEVERSION_STR
            VALUE "InternalName",     VER_INTERNALNAME_STR
            VALUE "LegalCopyright",   VER_LEGALCOPYRIGHT_STR
            VALUE "LegalTrademarks",  VER_LEGALTRADEMARKS_STR
            VALUE "OriginalFilename", VER_ORIGINALFILENAME_STR
            VALUE "ProductName",      VER_PRODUCTNAME_STR
            VALUE "ProductVersion",   VER_PRODUCTVERSION_STR
            VALUE "Comments",         VER_COMMENTS_STR
#ifdef PRIVATEBUILD
            VALUE "PrivateBuild",     VER_PRIVATEBUILD_STR
#endif
#ifdef SPECIALBUILD
            VALUE "SpecialBuild",     VER_SPECIALBUILD_STR
#endif
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        // Translation: US English (0x0409), Unicode (1200)
        VALUE "Translation", 0x0409, 1200
    END
END

//=============================================================================
// END OF RESOURCE FILE
//
// VERIFICATION CHECKLIST:
// [✓] Version numbers defined (Major.Minor.Build.QFE)
// [✓] File type is VFT_DRV with VFT2_DRV_NETWORK subtype
// [✓] Company and product information complete
// [✓] Legal copyright and trademarks defined
// [✓] Debug/Release flags properly configured
// [✓] StringFileInfo contains all required fields
// [✓] VarFileInfo has correct Translation value
// [✓] Language is US English (0x0409) with Unicode (1200)
//=============================================================================
