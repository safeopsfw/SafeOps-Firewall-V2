# ============================================================================
# SafeOps IDS/IPS Rules - Suricata Native Format
# ============================================================================
# Format: .rules files (Suricata/Snort compatible)
# Reference: https://suricata.readthedocs.io/en/latest/rules/
# ============================================================================

# SQL Injection Detection
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB SQL Injection UNION SELECT"; flow:established,to_server; content:"UNION"; nocase; content:"SELECT"; nocase; distance:0; within:20; http_uri; classtype:web-application-attack; sid:1000001; rev:1; metadata:attack_target Server, signature_severity Major, tag SQLi, mitre_tactic_id TA0001, mitre_technique_id T1190;)

# XSS Attack Detection
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB Possible XSS Attack <script> tag"; flow:established,to_server; content:"<script"; nocase; http_uri; classtype:web-application-attack; sid:1000002; rev:1;)

# SSH Brute Force
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"ET EXPLOIT SSH Brute Force Attempt"; flow:to_server; threshold:type threshold, track by_src, count 5, seconds 60; content:"SSH-"; depth:4; classtype:attempted-admin; sid:1000003; rev:1; metadata:tag Brute_Force, mitre_tactic_id TA0006, mitre_technique_id T1110;)

# Known Malware C2 Domain
alert dns any any -> any any (msg:"ET MALWARE Known C2 Domain evil-malware-c2.com"; dns_query; content:"evil-malware-c2.com"; nocase; classtype:trojan-activity; sid:1000004; rev:1; reference:url,urlhaus.abuse.ch; metadata:tag C2, mitre_tactic_id TA0011, mitre_technique_id T1071;)

# Suspicious TLS Certificate
alert tls $EXTERNAL_NET any -> $HOME_NET any (msg:"ET POLICY TLS Certificate with suspicious CN .ru domain"; flow:established,to_server; tls.subject; content:".ru"; nocase; classtype:policy-violation; sid:1000005; rev:1;)

# Port Scan Detection
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET SCAN Port Scan Detected"; flags:S; threshold:type threshold, track by_src, count 20, seconds 10; classtype:attempted-recon; sid:1000006; rev:1;)

# Emotet Malware Traffic
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"ET MALWARE Emotet User-Agent"; flow:established,to_server; content:"User-Agent|3a 20|"; http_header; content:"Mozilla/4.0 (compatible|3b| MSIE 7.0|3b| Windows NT 6.1|3b| Trident/7.0"; fast_pattern; http_header; classtype:trojan-activity; sid:1000007; rev:1;)

# RDP Brute Force
alert tcp $EXTERNAL_NET any -> $HOME_NET 3389 (msg:"ET EXPLOIT RDP Brute Force Attempt"; flow:to_server; threshold:type threshold, track by_src, count 10, seconds 120; classtype:attempted-admin; sid:1000008; rev:1;)

# DNS Tunneling
alert dns $HOME_NET any -> any 53 (msg:"ET POLICY Possible DNS Tunneling - Long Query"; dns_query; content:"."; pcre:"/^.{50,}/"; threshold:type threshold, track by_src, count 5, seconds 60; classtype:policy-violation; sid:1000009; rev:1;)

# TLS Version Downgrade
alert tls $EXTERNAL_NET any -> $HOME_NET any (msg:"ET POLICY TLS Version 1.0 Detected"; tls.version:1.0; classtype:policy-violation; sid:1000010; rev:1;)

# Command Injection
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB Command Injection Attempt"; flow:established,to_server; content:"|3b|"; http_uri; pcre:"/;(cat|ls|wget|curl|bash|sh)/i"; classtype:web-application-attack; sid:1000011; rev:1;)

# Cobalt Strike Beacon
alert tls $EXTERNAL_NET any -> $HOME_NET any (msg:"ET MALWARE Cobalt Strike Default Certificate"; tls.cert_subject; content:"CN=Major Cobalt Strike"; classtype:trojan-activity; sid:1000012; rev:1; reference:url,www.cobaltstrike.com;)

# File Upload to External Site
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"ET POLICY File Upload to External Site"; flow:established,to_server; content:"POST"; http_method; content:"Content-Type|3a| multipart/form-data"; http_header; fileext:!".jpg|.png|.gif|.css|.js"; threshold:type threshold, track by_src, count 5, seconds 300; classtype:policy-violation; sid:1000013; rev:1;)

# SMB Lateral Movement
alert smb $HOME_NET any -> $HOME_NET any (msg:"ET EXPLOIT SMB Admin Share Access Attempt"; smb.share; content:"ADMIN$"; classtype:attempted-admin; sid:1000014; rev:1;)

# Cryptocurrency Mining
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"ET POLICY Cryptocurrency Mining Pool Connection"; flow:established,to_server; content:"stratum+tcp"; http_uri; classtype:policy-violation; sid:1000015; rev:1;)

# ============================================================================
# Variable Definitions (typically in suricata.yaml or separate vars file)
# ============================================================================
# HOME_NET: "192.168.0.0/16"
# EXTERNAL_NET: "!$HOME_NET"
# HTTP_SERVERS: "$HOME_NET"
# SMTP_SERVERS: "$HOME_NET"
# DNS_SERVERS: "$HOME_NET"
# SQL_SERVERS: "$HOME_NET"

# ============================================================================
# Rule Format Explained:
# ============================================================================
# action protocol src_ip src_port direction dst_ip dst_port (options)
#
# Actions: alert, drop, reject, pass
# Protocols: tcp, udp, icmp, ip, http, dns, tls, ssh, smb
# Direction: -> (to), <> (bidirectional)
#
# Common Options:
# - msg: Alert message
# - sid: Signature ID (unique)
# - rev: Revision number
# - flow: Flow characteristics (established, to_server, to_client)
# - content: Content to match
# - nocase: Case-insensitive matching
# - offset: Offset from beginning of payload
# - depth: How deep to search
# - distance: Distance from previous match
# - within: Within N bytes of previous match
# - pcre: Perl-compatible regex
# - threshold: Rate limiting
# - classtype: Classification type
# - reference: External reference
# - metadata: Additional metadata
# - http_uri, http_header, http_method: HTTP-specific matching
# - dns_query: DNS query matching
# - tls.*: TLS/SSL matching
# - fileext: File extension matching
# ============================================================================
